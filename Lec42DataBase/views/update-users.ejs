<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update-Users</title>
</head>
<body>
    <h1>Data is fetched from MongoDB</h1>
     
    <form action="/update-users/<%= user._id %>" method="post">

        <input type="text" name="name" placeholder="Enter name" value ="<%= user.name %>"><br><br>
        <input type="number" name="age"  placeholder="Enter age" value="<%= user.age %>"><br><br>
        <input type="text" name="city" placeholder="Enter city" value="<%= user.city %>"><br><br>
        <button type="submit">Update</button>
    </form>

</body>
</html>